# go to https://supabase.com/ and create a new project, then copy the url and anon key to the .env.local file
VITE_SUPABASE_URL=your_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# These are just example credentials for testing purposes. Do not use them in production.
VITE_STORAGE_KEY=your_storage_key_here